PORT=5000
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/jewelry_db
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long
JWT_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Metal rates API (goldapi.io - free tier available)
GOLD_API_KEY=your_goldapi_key
# Or use metals.live (no key needed for basic)
METALPRICE_API_KEY=your_metalpriceapi_key

# Admin credentials (for seeding)
ADMIN_EMAIL=admin@youjewelry.com
ADMIN_PASSWORD=Admin@123456

# Email (SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=Akshar Jewellers <no-reply@Aksharjewellers.com>
